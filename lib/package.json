{
  "name": "@maw1a/service-grpc",
  "version": "1.0.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "A guide to building grpc services with typescript.",
  "keywords": [
    "grpc",
    "typescript",
    "protobuf",
    "buf",
    "protos"
  ],
  "author": "maw1a <ahmedmawia.dev@gmail.com",
  "license": "ISC",
  "homepage": "https://github.com/maw1a/service-grpc#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maw1a/service-grpc.git",
    "directory": "lib"
  },
  "bugs": {
    "url": "https://github.com/maw1a/service-grpc/issues"
  },
  "discussions": "https://github.com/maw1a/service-grpc/discussions",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@10.26.1"
}
